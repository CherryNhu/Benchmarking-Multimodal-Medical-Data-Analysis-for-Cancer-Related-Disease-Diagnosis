# Python/cache
__pycache__/
*.py[cod]
*.so

# OS/editor
.DS_Store
Thumbs.db
.vscode/

# Keep only lightweight, paper-relevant content under MMIST
MMIST/*
!MMIST/scripts/
!MMIST/scripts/**
!MMIST/MYNOTE.txt
!MMIST/feat/

# Keep only tabular metadata/splits from feature folders
MMIST/feat/*
!MMIST/feat/*/
!MMIST/feat/**/
!MMIST/feat/**/*.csv

# Exclude heavyweight experiment artifacts
MMIST/checkpoint/
MMIST/logs/
MMIST/runs/
MMIST/mmist-ccRCC-MMIST/
MMIST/mmist-ccRCC-SYNAPSE/
